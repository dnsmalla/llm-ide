# Reference .env for self-hosted deployments.  Copy to `.env` and fill
# in the two required secrets before starting the server.

# --- Required ---------------------------------------------------------

# Signs JWT access + refresh tokens.
# Generate with: openssl rand -base64 48
# Zero-downtime rotation:
#   1. Set LLMIDE_JWT_SECRET_PREVIOUS = current value of LLMIDE_JWT_SECRET
#   2. Set LLMIDE_JWT_SECRET           = new value
#   3. Deploy — old tokens remain valid until their TTL expires (15 min default)
#   4. After one TTL window, clear LLMIDE_JWT_SECRET_PREVIOUS
LLMIDE_JWT_SECRET=
LLMIDE_JWT_SECRET_PREVIOUS=

# Master key for the per-user encrypted credential vault.  Rotating
# this strands every existing stored credential — re-key carefully.
# Generate with: openssl rand -base64 48
LLMIDE_VAULT_KEY=

# --- Optional ---------------------------------------------------------

# Bind address.  Defaults to loopback (127.0.0.1) — the safe local-only mode.
# This server terminates NO TLS, so binding a non-loopback address (e.g.
# 0.0.0.0 for container/k8s) is REFUSED at startup unless you also set
# LLMIDE_ALLOW_REMOTE=1 and front the server with a TLS-terminating proxy.
LLMIDE_HOST=127.0.0.1
LLMIDE_PORT=3456
# Set to 1 ONLY when binding a non-loopback LLMIDE_HOST behind a TLS proxy.
LLMIDE_ALLOW_REMOTE=0

# Logging.
LLMIDE_LOG_LEVEL=info        # trace | debug | info | warn | error
LLMIDE_LOG_JSON=1             # 1 forces JSON; 0 prints pretty on TTY

# JWT TTLs (seconds).
LLMIDE_ACCESS_TTL_SEC=900           # 15 min
LLMIDE_REFRESH_TTL_SEC=2592000      # 30 days

# Bcrypt cost factor.  10 is fast, 12 is the modern default, 14 is
# CPU-painful.  Higher is slower-to-hash AND slower-to-attack.
LLMIDE_BCRYPT_COST=12

# Registration — defaults to CLOSED in production (NODE_ENV=production).
# Set to 0 to allow self-registration (e.g. initial team bootstrap).
# In dev (NODE_ENV != production) registration is open by default.
LLMIDE_DISABLE_REGISTRATION=1

# Trust X-Forwarded-For headers.  Only enable when running behind a
# reverse proxy you control (nginx/Caddy/k8s ingress).  Without this
# the audit log records the proxy's address rather than the real client.
LLMIDE_TRUST_PROXY=0

# Body size cap (MB).
LLMIDE_BODY_LIMIT_MB=8

# Claude model overrides.  Default is claude-sonnet-4-6 for all agents.
# Use LLMIDE_SUMMARIZE_MODEL to run a heavier model for meeting summaries.
LLMIDE_MODEL=claude-sonnet-4-6
LLMIDE_SUMMARIZE_MODEL=claude-opus-4-8

# Per-tier sub-model routing for the agent loops (all optional; unset
# falls back to LLMIDE_MODEL):
#   LLMIDE_AGENT_MODEL     — global user-facing agent
#   LLMIDE_INTERNAL_MODEL  — internal app-state agent (defaults to AGENT_MODEL)
#   LLMIDE_SUBAGENT_MODEL  — plugin subagent leaf calls (defaults to AGENT_MODEL);
#                            a subagent's own frontmatter `model:` wins over this.
#LLMIDE_AGENT_MODEL=
#LLMIDE_INTERNAL_MODEL=
#LLMIDE_SUBAGENT_MODEL=claude-haiku-4-5

# Anthropic API version header (rarely needs changing).
#LLMIDE_ANTHROPIC_VERSION=2023-06-01

# Comma-separated extra allowed CORS origins beyond chrome-extension://*
# / localhost / 127.0.0.1.  Useful when the side panel is hosted as a
# regular web app under your own domain.
LLMIDE_CORS_ORIGINS=

# Database path inside the container.
LLMIDE_DB_PATH=/app/kb/data.db

# Bind only loopback by default; set BIND_HOST=0.0.0.0 to publish.
BIND_HOST=127.0.0.1

# --- Automated backups ------------------------------------------------

# How often to create a backup (hours).  Set to 0 to disable.
# A backup is also created once at server startup.
LLMIDE_BACKUP_INTERVAL_HOURS=24

# Directory to write backup files.  Defaults to <db-dir>/backups/.
# Point at a mounted volume for off-server durability.
# LLMIDE_BACKUP_DIR=/mnt/backups

# How many backup files to retain.  Older ones are pruned automatically.
LLMIDE_BACKUP_RETAIN=7

# --- Repo-grounding memory block --------------------------------------
# Bounds the graphify-out/memory block injected into the agent each turn
# (see docs/superpowers/plans/2026-07-01-memory-professionalization.md).
# Larger = deeper grounding but more prompt tokens per turn.
LLMIDE_MEM_PER_FILE_CHARS=4000    # per non-chat memory file (repo/graph/doc-notes)
LLMIDE_MEM_TOTAL_CHARS=16000      # total across all memory files
LLMIDE_MEM_MAX_REPOS=2            # how many indexed repos contribute memory
LLMIDE_MEM_CHAT_FILE_CHARS=8000   # chat-memory.md cap — SHARED by reader + writer (keep them equal)
LLMIDE_MEM_MAX_FACTS=100          # max durable facts kept in chat-memory.md
