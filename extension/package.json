{
  "name": "llm-ide-extension",
  "version": "3.0.0",
  "private": true,
  "type": "module",
  "description": "Conversation-driven autonomous project system — meetings → plans → tickets → code, fully local",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "start": "bash start.sh",
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "type-check": "tsc --noEmit",
    "server": "node server.mjs",
    "backup": "node scripts/backup.mjs",
    "test": "node --test tests/*.test.mjs",
    "test:watch": "node --test --watch tests/*.test.mjs",
    "lint": "eslint src agents kb core graphkit connectors llm_agent server scripts server.mjs",
    "lint:fix": "eslint src agents kb core graphkit connectors llm_agent server scripts server.mjs --fix",
    "format": "prettier --write 'src/**/*.{ts,tsx,css}'",
    "format:check": "prettier --check 'src/**/*.{ts,tsx,css}'",
    "package": "npm run build && cd dist && zip -r -X ../extension-v$npm_package_version.zip . && cd ..",
    "init": "cd .. && bash setup.sh",
    "sync:skills": "bash scripts/sync-skills.sh"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.10.0",
    "docx": "^9.7.0",
    "imapflow": "^1.4.1",
    "js-yaml": "^4.1.1",
    "mailparser": "^3.9.10",
    "react": "^19.2.7",
    "react-dom": "^18.3.1",
    "react-markdown": "^9.0.1",
    "rehype-sanitize": "^6.0.0"
  },
  "devDependencies": {
    "@crxjs/vite-plugin": "^2.0.0-beta.28",
    "@eslint/js": "^9.0.0",
    "@types/chrome": "^0.0.287",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "eslint": "^9.0.0",
    "prettier": "^3.4.0",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.0.0",
    "vite": "^5.4.11"
  },
  "optionalDependencies": {
    "@rollup/rollup-darwin-arm64": "^4.60.3"
  }
}
