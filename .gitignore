# Dev-only secrets generated by server/config.mjs when env vars
# MEETNOTES_JWT_SECRET / MEETNOTES_VAULT_KEY are not set.  These must
# NEVER be committed — production deployments inject the secrets via
# their secret store and the config refuses to start without them.
kb/.dev-secrets.json

# Local KB — every install gets its own SQLite store.
kb/data.db
kb/data.db-shm
kb/data.db-wal
kb/*.db-journal
kb/backups/

# Test-created SQLite files (per-test temp DBs).
extension/tests/_*.db
extension/tests/_*.db-*

# Node
node_modules/
extension/node_modules/
extension/bot-worker/node_modules/
*.log
*.log.old
npm-debug.log*
*.out

# Build outputs
extension/dist/
extension/bot-worker/dist/
extension/dashboard/dist/

# Packaged extension archive — rebuild via `npm run build` then zip,
# don't commit a 40+ MB zip into git history.
extension.zip

# Bot-worker Chromium profile — contains persistent Google session.
extension/bot-worker/bot-profile/

# Mac build artefacts
mac/.build/
mac/LlmIdeMac.app/
mac/LlmIdeMac_*.dmg

# Editor / OS
.DS_Store
.idea/
.vscode/
*.swp

# Superpowers — ephemeral process state, not source
.superpowers/

# Local environment files
.env
.env.local
extension/.env
extension/bot-worker/.env

# Docs tooling
.venv-docs/
site/
docs/.cache/

# Python
__pycache__/
*.pyc
.claude/worktrees/

# Regenerated code-graph / Graphify output (per-checkout, rebuilt by the app's
# indexer — the same dirs RepoFileWatcher treats as regen output). These are
# generated, not source, so they must not show up as untracked "changes" in the
# IDE git panel or the agent's git status.
graphify-out/
system/
.code-notes/
.understand-anything/

# Personal scratch / design notes kept locally, not part of the repo.
flag-semantics-flow-zero.md
